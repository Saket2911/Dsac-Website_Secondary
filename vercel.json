{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/contests/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/leaderboard/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/daily-question/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/user/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/client/assets/$1"
    },
    {
      "src": "/vite.svg",
      "dest": "/client/vite.svg"
    },
    {
      "src": "/dsac-logo.png",
      "dest": "/client/dsac-logo.png"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}